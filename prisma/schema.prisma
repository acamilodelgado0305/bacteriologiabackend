generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Rol {
  admin
  estudiante
  docente
  bacteriologo
}

enum Semestre {
  noveno
  decimo
}

model Usuario {
  id            String    @id @default(uuid())
  nombre        String    @db.VarChar(100)
  apellido      String    @db.VarChar(100)
  email         String    @unique @db.VarChar(150)
  password      String
  rol            Rol       @default(estudiante)
  esAdminDocente Boolean   @default(false) @map("es_admin_docente")
  activo         Boolean   @default(true)
  ultimoAcceso  DateTime? @map("ultimo_acceso")
  creadoEn      DateTime  @default(now()) @map("creado_en")
  actualizadoEn DateTime  @updatedAt @map("actualizado_en")

  perfil                  Estudiante?       @relation("UsuarioEstudiante")
  entidadesPersonal       EntidadPersonal[]
  registrosComoDocente    RegistroDiario[]  @relation("DocenteRegistro")
  registrosComoBacteriologo RegistroDiario[] @relation("BacteriologoRegistro")

  @@map("usuarios")
}

model Entidad {
  id            String    @id @default(uuid())
  nombre        String    @db.VarChar(200)
  direccion     String?   @db.VarChar(300)
  ciudad        String?   @db.VarChar(100)
  departamento  String?   @db.VarChar(100)
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now()) @map("creado_en")
  actualizadoEn DateTime  @updatedAt @map("actualizado_en")

  estudiantes Estudiante[]
  examenes    Examen[]
  personal    EntidadPersonal[]

  @@map("entidades")
}

model EntidadPersonal {
  id        String   @id @default(uuid())
  entidadId String   @map("entidad_id")
  usuarioId String   @map("usuario_id")
  creadoEn  DateTime @default(now()) @map("creado_en")

  entidad Entidad @relation(fields: [entidadId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([entidadId, usuarioId])
  @@map("entidad_personal")
}

model Examen {
  id            String   @id @default(uuid())
  nombre        String   @db.VarChar(200)
  area          String?  @db.VarChar(100)
  entidadId     String   @map("entidad_id")
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  entidad   Entidad          @relation(fields: [entidadId], references: [id])
  registros RegistroExamen[]

  @@map("examenes")
}

model Estudiante {
  id              String    @id @default(uuid())
  usuarioId       String    @unique @map("usuario_id")
  numeroDocumento String    @unique @map("numero_documento") @db.VarChar(20)
  semestre        Semestre
  entidadId       String?   @map("entidad_id")
  cierreId        String?   @map("cierre_id")
  fechaInicio     DateTime? @map("fecha_inicio") @db.Date
  fechaFin        DateTime? @map("fecha_fin") @db.Date
  creadoEn        DateTime  @default(now()) @map("creado_en")
  actualizadoEn   DateTime  @updatedAt @map("actualizado_en")

  usuario   Usuario         @relation("UsuarioEstudiante", fields: [usuarioId], references: [id], onDelete: Cascade)
  entidad   Entidad?        @relation(fields: [entidadId], references: [id])
  cierre    CierreSemestre? @relation(fields: [cierreId], references: [id])
  registros RegistroDiario[]

  @@map("estudiantes")
}

model CierreSemestre {
  id               String   @id @default(uuid())
  nombre           String   @db.VarChar(200)
  descripcion      String?
  fechaCierre      DateTime @default(now()) @map("fecha_cierre")
  totalEstudiantes Int      @default(0) @map("total_estudiantes")
  totalRegistros   Int      @default(0) @map("total_registros")
  creadoEn         DateTime @default(now()) @map("creado_en")

  registros   RegistroDiario[]
  estudiantes Estudiante[]

  @@map("cierres_semestre")
}

model RegistroDiario {
  id                       String    @id @default(uuid())
  estudianteId             String    @map("estudiante_id")
  docenteSupervisorId      String?   @map("docente_supervisor_id")
  bacteriologoSupervisorId String?   @map("bacteriologo_supervisor_id")
  cierreId                 String?   @map("cierre_id")
  fecha                    DateTime  @db.Date
  horaEntrada              String?   @map("hora_entrada") @db.VarChar(5)
  horaSalida               String?   @map("hora_salida")  @db.VarChar(5)
  observaciones            String?
  firmaEstudiante          String?   @map("firma_estudiante")
  firmaEstudianteFecha     DateTime? @map("firma_estudiante_fecha")
  firmaDocente                  String?   @map("firma_docente")
  firmaDocenteFecha             DateTime? @map("firma_docente_fecha")
  observacionesDocente          String?   @map("observaciones_docente")
  nombreFirmanteDocente         String?   @map("nombre_firmante_docente")
  firmaBacteriologo             String?   @map("firma_bacteriologo")
  firmaBacteriologoFecha        DateTime? @map("firma_bacteriologo_fecha")
  nombreFirmanteBacteriologo    String?   @map("nombre_firmante_bacteriologo")
  firmado                       Boolean   @default(false)
  creadoEn                 DateTime  @default(now()) @map("creado_en")
  actualizadoEn            DateTime  @updatedAt @map("actualizado_en")

  estudiante           Estudiante      @relation(fields: [estudianteId], references: [id])
  docenteSupervisor    Usuario?        @relation("DocenteRegistro", fields: [docenteSupervisorId], references: [id])
  bacteriologoSupervisor Usuario?      @relation("BacteriologoRegistro", fields: [bacteriologoSupervisorId], references: [id])
  cierre               CierreSemestre? @relation(fields: [cierreId], references: [id])
  examenes             RegistroExamen[]

  @@unique([estudianteId, fecha])
  @@map("registros_diarios")
}

model RegistroExamen {
  id         String @id @default(uuid())
  registroId String @map("registro_id")
  examenId   String @map("examen_id")
  cantidad   Int    @default(1)

  registro RegistroDiario @relation(fields: [registroId], references: [id], onDelete: Cascade)
  examen   Examen         @relation(fields: [examenId], references: [id])

  @@unique([registroId, examenId])
  @@map("registros_examenes")
}
